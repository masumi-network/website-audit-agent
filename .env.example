# ── Sokosumi ────────────────────────────────────────────────────────────────────
SOKOSUMI_API_URL=https://api.preprod.sokosumi.com
SOKOSUMI_COWORKER_API_KEY=your_coworker_api_key_here
SOKOSUMI_TASK_POLLER_ENABLED=true
SOKOSUMI_TASK_POLL_INTERVAL_MS=15000

# ── Google PageSpeed Insights ────────────────────────────────────────────────────
# Free — get one at https://console.cloud.google.com (higher rate limits)
PAGESPEED_API_KEY=your_pagespeed_api_key_here

# ── Google Service Account ───────────────────────────────────────────────────────
# Create a service account in Google Cloud Console, download the JSON key.
# Grant it read access to your GA4 property, Search Console, and GTM container.
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=/path/to/service-account-key.json

# ── Google Analytics 4 ──────────────────────────────────────────────────────────
GA4_PROPERTY_ID=123456789
# Report window in days (default 30)
GA4_LOOKBACK_DAYS=30

# ── Google Search Console ────────────────────────────────────────────────────────
GSC_SITE_URL=https://yoursite.com
GSC_LOOKBACK_DAYS=28

# ── Google Tag Manager ──────────────────────────────────────────────────────────
GTM_ACCOUNT_ID=1234567
GTM_CONTAINER_ID=GTM-XXXXXXX

# ── Microsoft Clarity ──────────────────────────────────────────────────────────
# Get your project ID from Clarity dashboard
CLARITY_PROJECT_ID=your_clarity_project_id
# API token — Settings → Access control → API token
CLARITY_API_TOKEN=your_clarity_api_token

# ── Google Docs (for report output) ─────────────────────────────────────────────
# Folder ID in Google Drive where audit reports will be saved
GOOGLE_DRIVE_FOLDER_ID=your_drive_folder_id_here

# ── Audit Storage ────────────────────────────────────────────────────────────────
# Local path where audit history JSON files are saved (for weekly diffs)
AUDIT_HISTORY_PATH=./audit-history

# ── Masumi Payments (optional) ──────────────────────────────────────────────────
# MASUMI_PAYMENT_API_URL=https://payment.preprod.masumi.network
# MASUMI_PAYMENT_API_TOKEN=your_masumi_token
# MASUMI_AGENT_IDENTIFIER=website-audit-agent
# MASUMI_NETWORK=Preprod
